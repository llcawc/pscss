{
  "name": "@pasmurno/pscss",
  "version": "0.0.6",
  "description": "Gulp plugin for simple processing of sass styles and modern css style",
  "keywords": [
    "bootstrap",
    "bundle",
    "css",
    "gulp",
    "minify",
    "optimize",
    "pcss",
    "purge",
    "sass",
    "scss",
    "styles"
  ],
  "homepage": "https://github.com/llcawc/pscss",
  "license": "MIT",
  "author": "llcawc",
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/pscss.cjs",
  "types": "./dist/pscss.d.cts",
  "exports": {
    ".": {
      "import": "./dist/pscss.js",
      "require": "./dist/pscss.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest",
    "lint": "oxlint",
    "fix": "oxlint --fix",
    "check": "oxfmt --check",
    "fmt": "oxfmt",
    "validate": "oxlint && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "tsc": "tsc",
    "dev": "tsdown --watch",
    "build": "tsdown"
  },
  "dependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
    "plugin-error": "^2.0.1",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.2.0",
    "sass-embedded": "1.78.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/postcss-import": "^14.0.3",
    "@types/vinyl": "^2.0.12",
    "@typescript/native-preview": "7.0.0-dev.20260329.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "source-map": "^0.7.6",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vinyl": "^3.0.1",
    "vitest": "^4.1.2"
  },
  "module": "./dist/pscss.js"
}
