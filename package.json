{
  "name": "@pasmurno/pscss",
  "version": "0.0.5",
  "description": "Gulp plugin for simple processing of sass styles and modern css style",
  "keywords": [
    "gulp",
    "optimize",
    "bundle",
    "minify",
    "purge",
    "styles",
    "css",
    "sass",
    "scss",
    "pcss",
    "bootstrap"
  ],
  "license": "MIT",
  "author": "llcawc",
  "homepage": "https://github.com/llcawc/pscss",
  "type": "module",
  "main": "./libs/pscss.js",
  "exports": "./libs/pscss.js",
  "types": "./libs/pscss.d.ts",
  "files": [
    "libs",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "lint": "oxlint",
    "fix": "oxlint --fix",
    "fmt": "oxfmt",
    "check": "oxfmt --check",
    "typecheck": "tsc -p ./ts --noEmit",
    "validate": "oxlint && tsc -p ./ts --noEmit",
    "tsc": "tsc -p ./ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/postcss-import": "^14.0.3",
    "@types/vinyl": "^2.0.12",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "source-map": "^0.7.6",
    "typescript": "^6.0.2",
    "vinyl": "^3.0.1"
  },
  "dependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
    "plugin-error": "^2.0.1",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.2.0",
    "sass-embedded": "1.78.0"
  }
}
